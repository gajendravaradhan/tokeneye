# ── TokenEye Environment Variables ──────────────────────────────
# Copy this file to .env and adjust as needed.
# All variables are optional — sensible defaults are used when absent.

# Path to the TokenEye config file (JSON format).
# Default: ~/.config/tokeneye/config.json
# TOKENEYE_CONFIG="~/.config/tokeneye/config.json"

# Path to the SQLite metrics database.
# Default: ~/.config/tokeneye/metrics.db
# TOKENEYE_DB_PATH="~/.config/tokeneye/metrics.db"

# Comma-separated list of allowed CORS origins for the dashboard API.
# Only origins in this list (plus localhost) may access /api/* endpoints.
# Default: http://localhost:8788,http://127.0.0.1:8788,http://localhost:3000,http://127.0.0.1:3000
# TOKENEYE_ALLOWED_ORIGINS="http://localhost:8788,http://127.0.0.1:8788"

# Maximum requests per client per 60-second sliding window.
# Clients exceeding this receive HTTP 429 (Too Many Requests).
# Default: 300
# TOKENEYE_RATE_LIMIT=300
